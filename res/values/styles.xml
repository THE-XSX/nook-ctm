<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@android:style/Theme.Holo.NoActionBar">
        <item name="android:textAppearance">@style/MooTextAppearance</item>
        <item name="android:textViewStyle">@style/MooTextViewStyle</item>
    </style>
    <style name="MooTextAppearance" parent="@android:style/TextAppearance">
        <item name="android:textSize">18.0sp</item>
        <item name="android:textColor">@android:color/black</item>
    </style>
    <style name="MooTextViewStyle" parent="@android:style/Widget.TextView">
        <item name="android:textColor">@android:color/black</item>
    </style>
    <style name="NtxSwitchStyle">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:thumb">@drawable/ntx_switch_thumb</item>
        <item name="android:switchTextAppearance">@style/NtxSwitchTextStyle</item>
        <item name="android:track">@drawable/ntx_switch_track</item>
    </style>
    <style name="NtxSwitchTextStyle">
        <item name="android:textSize">20.0dip</item>
        <item name="android:textColor">@android:color/black</item>
    </style>
    <style name="CinnySwitchStyle">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:thumb">@drawable/switch_thumb_button</item>
        <item name="android:switchTextAppearance">@style/CinnySwitchTextStyle</item>
        <item name="android:track">@drawable/switch_track_selctor</item>
    </style>
    <style name="CinnySwitchTextStyle">
        <item name="android:textSize">18.0dip</item>
        <item name="android:textColor">@android:color/black</item>
    </style>
</resources>
